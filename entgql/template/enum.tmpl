{{/* gotype: entgo.io/ent/entc/gen.Type */}}

{{ define "import/additional/graphql-enum" }}
	"github.com/99designs/gqlgen/graphql"
{{ end }}

{{ define "meta/additional/graphql-enum" }}

{{ range $f := $.EnumFields }}
	{{ $enum := trimPackage $f.Type.String $.Package -}}
	{{- if not $f.HasGoType }}
		// MarshalGQL implements graphql.Marshaler interface.
		func (e {{ $enum }}) MarshalGQL(w io.Writer) {
			io.WriteString(w, strconv.Quote(e.String()))
		}

		// UnmarshalGQL implements graphql.Unmarshaler interface.
		func (e *{{ $enum }}) UnmarshalGQL(val interface{}) error {
			str, ok := val.(string)
			if !ok {
				return fmt.Errorf("enum %T must be a string", val)
			}
			*e = {{ $enum }}(str)
			if err := {{ $f.Validator }}(*e); err != nil {
				return fmt.Errorf("%s is not a valid {{ $enum }}", str)
			}
			return nil
		}
	{{- else }}
		var (
			// {{ $enum }} must implement graphql.Marshaler.
			 _ graphql.Marshaler = (*{{ $enum }})(nil)
			// {{ $enum }} must implement graphql.Unmarshaler.
			 _ graphql.Unmarshaler = (*{{ $enum }})(nil)
		)
	{{- end }}
{{ end }}
{{ end }}

{{ define "enum/marshal" }}
package ent

import (
	"fmt"
	"io"
	"strconv"
)

{{- range $node := $.Nodes }}
	{{- range $field := $node.Fields }}
		{{- if $field.IsEnum }}
			{{- $type := printf "%s.%s" $node.Package $field.StructField }}
			{{- $funcName := printf "%s%s" $node.Name $field.StructField }}

			// Marshal{{ $funcName }} handles GraphQL marshaling for {{ $type }}
			func Marshal{{ $funcName }}(val {{ $type }}) MarshalFunc {
				return func(w io.Writer) {
					io.WriteString(w, strconv.Quote(val.String()))
				}
			}

			// Unmarshal{{ $funcName }} handles GraphQL unmarshaling for {{ $type }}
			func Unmarshal{{ $funcName }}(v interface{}) ({{ $type }}, error) {
				str, ok := v.(string)
				if !ok {
					return "", fmt.Errorf("enums must be strings")
				}
				val := {{ $type }}(str)
				if err := {{ $node.Package }}.{{ $field.StructField }}Validator(val); err != nil {
					return "", fmt.Errorf("%s is not a valid %s", str, "{{ $field.StructField }}")
				}
				return val, nil
			}
		{{- end }}
	{{- end }}
{{- end }}

type MarshalFunc func(io.Writer)
func (f MarshalFunc) MarshalGQL(w io.Writer) { f(w) }
{{ end }}
